<style>.giosg-chat-container{width:310px;height:400px;display:flex;flex-direction:column;background-color:#fff;border-radius:4px;border:1px solid #efeff2;font-family:Arial,Helvetica,sans-serif}.giosg-chat-header{height:60px;padding:0 16px;background-color:#fff;border-radius:4px 4px 0 0;display:flex;align-items:center;cursor:move}.giosg-chat-dialog-agent-avatar-image{width:40px;height:40px;background-size:100% 100%;border-radius:100%;display:none}.giosg-chat-dialog-agent-avatar-image.giosg-chat-dialog-agent-avatar-image-visible{display:block}.giosg-chat-dialog-title-text{flex-grow:1;text-align:center;font-weight:bold;font-size:14px;color:#000}.giosg-chat-dialog-close-button{cursor:pointer;background-color:#fff;border:none;font-size:20px;font-weight:700;line-height:1em;color:#757575;text-shadow:0 1px 0 #fff;height:1em;width:1em;padding:0;margin:0;text-decoration:none;opacity:1;text-align:center;min-width:unset}.giosg-chat-dialog-close-button:hover{color:#000}.giosg-chat-dialog-close-button:focus{outline:none}.giosg-chat-dialog-iframe-container{flex-grow:1;height:0px}.giosg-chat-dialog-iframe-container iframe{display:block;height:100%;width:100%;border:0px;-ms-user-select:text !important}.giosg-chat-footer{height:37px;width:calc(100% - 16px);margin:0 8px;display:flex;flex-direction:row-reverse}.giosg-chat-footer-giosg-logo-link{padding:0;margin:0;text-decoration:none;opacity:1;text-align:center;display:flex;align-items:center;flex-shrink:0}.giosg-chat-footer-giosg-logo-image{height:25px}.giosg-chat-footer-customer-logo-image{flex-grow:1;flex-shrink:1;height:37px;min-width:0;width:0}.dialog-transfer-effect{border:1px solid gray;background:#000;opacity:.4;z-index:99999999}</style><style id="giosg-styles">@keyframes accessabilityButtonJiggle{0%{transform:scale(1);outline:2px solid rgba(0,0,0,0)}10%{outline:2px solid #000}33%{transform:scale(1.05)}66%{transform:scale(0.9)}100%{transform:scale(1)}}@keyframes giosg-animation-spawn{0%{transform:translateY(50px);opacity:0}100%{transform:translateY(0);opacity:1}}@keyframes giosg-animation-spawn-reverse{0%{transform:translateY(0);opacity:1}100%{transform:translateY(50px);opacity:0}}@keyframes giosg-animation-wiggle-icon{0%{transform:rotateZ(0deg);animation-timing-function:ease-in-out}33.33%{transform:rotateZ(-12deg);animation-timing-function:ease-in-out}66.67%{transform:rotateZ(12deg);animation-timing-function:ease-in-out}100%{transform:rotateZ(0deg);animation-timing-function:linear}}@keyframes giosg-animation-wiggle-count{0%{transform:scale(1);animation-timing-function:linear}50%{transform:scale(1.2);animation-timing-function:linear}100%{transform:scale(1);animation-timing-function:linear}}.giosg-animation-spawn{animation-name:giosg-animation-spawn;animation-duration:.2s;animation-timing-function:cubic-bezier(0.39, 0.575, 0.565, 1);animation-delay:0;animation-fill-mode:both}.giosg-animation-spawn-reverse{animation-name:giosg-animation-spawn-reverse;animation-duration:.3s;animation-timing-function:cubic-bezier(0.25, 0.46, 0.45, 0.94);animation-delay:0;animation-fill-mode:both}.giosg-animation-wiggle-icon{animation-name:giosg-animation-wiggle-icon;animation-duration:.3s;animation-timing-function:linear;animation-delay:0;animation-fill-mode:forwards}.giosg-animation-wiggle-count{animation-name:giosg-animation-wiggle-count;animation-duration:.3s;animation-timing-function:linear;animation-delay:0;animation-fill-mode:forwards}.giosg-chat-button{cursor:pointer;border:0;padding:0;margin:0;bottom:15px;position:fixed;right:15px;z-index:99999998;border-radius:50%;overflow:initial;text-shadow:initial;box-shadow:initial;background-color:rgba(0,0,0,0);-webkit-tap-highlight-color:rgba(255,255,255,0);-webkit-tap-highlight-color:rgba(0,0,0,0)}.giosg-chat-button:hover,.giosg-chat-button:focus-visible{filter:brightness(115%);background-color:rgba(0,0,0,0);overflow:initial;text-shadow:initial;box-shadow:initial}.giosg-chat-button:focus{outline:0}.giosg-chat-button:focus-visible{border-radius:50%;box-shadow:#